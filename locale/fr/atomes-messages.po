"! Toujours une section FORCE_EVAL qui décrit\n"
"! la méthode pour calculer l'énergie et les forces\n"
"!\n"
"&FORCE_EVAL\n"
"  MÉTHODE QUICKSTEP\n"
"  &TFD\n"
"! Précisez d'abord les fichiers qui seront utilisés par la suite \n"
"    BASIS_SET_FILE_NAME "

# File: calc/cp2k/cp2k_print.c, Line: 138
msgid "\n"
"! Going to the Multi-grids section\n"
"    &MGRID\n"
"      CUTOFF "
msgstr "\n"
"! Accéder à la section Multi-grilles\n"
"    &MGRID\n"
"      COUPE "

# File: calc/cp2k/cp2k_print.c, Line: 142
msgid "                      ! => Cutoff of the finest grid level\n"
"      NGRIDS "
msgstr "                      ! => Rayon de coupure du niveau de grille le plus fin\n"
"      NGRIDS "

# File: calc/cp2k/cp2k_print.c, Line: 145
msgid "                       ! => Number of multigrids to use, default = 4\n"
"    &END MGRID\n"
"! Going to the Quickstep Setup section\n"
"    &QS\n"
"      METHOD "
msgstr "                       ! => Nombre de multigrilles à utiliser, par défaut = 4\n"
"    &FIN MGRID\n"
"! Accéder à la section Configuration de Quickstep\n"
"    &QS\n"
"      MÉTHODE "

# File: calc/cp2k/cp2k_print.c, Line: 152
msgid "\n"
"      EPS_DEFAULT 1.0E-12                   ! => Default value is 1.0E-10\n"
"      MAP_CONSISTENT TRUE                   ! => This is the default value\n"
msgstr "\n"
"      EPS_DEFAULT 1.0E-12                   ! => La valeur par défaut est 1.0E-10\n"
"      MAP_CONSISTENT VRAI                   ! => C'est la valeur par défaut\n"

# File: calc/cp2k/cp2k_print.c, Line: 153
msgid "      EXTRAPOLATION_ORDER 3                 ! => This is the default value\n"
"    &END QS\n"
msgstr "      EXTRAPOLATION_ORDER 3                 ! => C'est la valeur par défaut\n"
"    &FIN QS\n"

# File: calc/cp2k/cp2k_print.c, Line: 155
msgid "! Going to the Self Consistent Field section\n"
"    &SCF\n"
"! Maximum number of cycle\n"
"      SCF_GUESS "
msgstr "! Accéder à la section Champ auto-cohérent\n"
"    &SCF\n"
"! Nombre maximum de cycles\n"
"      SCF_GUESS "

# File: calc/cp2k/cp2k_print.c, Line: 160
msgid "                ! => Initial guess for the wave-function\n"
"      MAX_SCF "
msgstr "                ! => Estimation initiale de la fonction d'onde\n"
"      MAX_SCF "

# File: calc/cp2k/cp2k_print.c, Line: 162
msgid "                ! => Maximum number of SCF cycles\n"
"      EPS_SCF "
msgstr "                ! => Nombre maximum de cycles SCF\n"
"      EPS_SCF "

# File: calc/cp2k/cp2k_print.c, Line: 165
msgid "                  ! => Threshold for the SCF convergence\n"
"! If after the ${SCF_NCYCLES} first SCF steps no convergence has been reached\n"
"! more SCF cycles can be done updating the preconditioner. \n"
"! Detail information is then presented in the 'Outer' SCF section\n"
"      &OUTER_SCF\n"
"        MAX_SCF "
msgstr "                  ! => Seuil de convergence SCF\n"
"! Si après les ${SCF_NCYCLES} premières étapes SCF aucune convergence n'a été atteinte\n"
"! davantage de cycles SCF peuvent être effectués en mettant à jour le préconditionneur. \n"
"! Des informations détaillées sont ensuite présentées dans la section SCF « Externe ».\n"
"      &OUTER_SCF\n"
"        MAX_SCF "

# File: calc/cp2k/cp2k_print.c, Line: 171
msgid "              ! => We update the preconditioner and start a new SCF cycle\n"
"                                            !    up to ${SCF_NCYCLES} x ${SCF_OCYCLES} can be computed\n"
"        EPS_SCF "
msgstr "              ! => On met à jour le préconditionneur et on démarre un nouveau cycle SCF\n"
"                                            !    jusqu'à ${SCF_NCYCLES} x ${SCF_OCYCLES} peuvent être calculés\n"
"        EPS_SCF "

# File: calc/cp2k/cp2k_print.c, Line: 175
msgid "                ! => Convergence threshold for the extra cycles\n"
"      &END OUTER_SCF\n"
"\n"
"! Going to the Orbital Transformation section\n"
"      &OT ON\n"
"        MINIMIZER "
msgstr "                ! => Seuil de convergence pour les cycles supplémentaires\n"
"      &END OUTER_SCF\n"
"\n"
"! Aller à la section Transformation Orbitale\n"
"      &OT SUR\n"
"        MINIMISEUR "

# File: calc/cp2k/cp2k_print.c, Line: 184
msgid "\n"
"        PRECONDITIONER FULL_ALL             ! => Preconditioner for the minimization scheme,\n"
"                                            !    FULL_ALL is the most effective state selective\n"
"                                            !    preconditioner and is based on diagonalization\n"
"        ENERGY_GAP 0.001                    ! => Underestimated value of the Gap (HOMO-LUMO) in a.u.\n"
"                                            !    to be used with the FULL_ALL preconditioner\n"
"      &END OT\n"
"\n"
"      &PRINT\n"
"! To tune the printing of the restart file\n"
"        &RESTART\n"
"          LOG_PRINT_KEY T                   ! => Printing on screen when restart file is written\n"
"          &EACH\n"
"            QS_SCF 0                        ! => Never write restart file(s) during the SCF cycle\n"
msgstr "\n"
"        PRÉCONDITIONNEUR FULL_ALL           ! => Préconditionneur pour le schéma de minimisation,\n"
"                                            !    FULL_ALL est le préconditionneur le plus efficace\n"
"                                            !    poru la sélection d'états et est basé sur la diagonalisation\n"
"        ÉCART_ÉNERGÉTIQUE 0,001             ! => Valeur sous-estimée du Gap (HOMO-LUMO) en a.u.\n"
"                                            !    à utiliser avec le préconditionneur FULL_ALL\n"
"      &FIN OT\n"
"\n"
"      &IMPRIMER\n"
"! Pour régler l'impression du fichier de redémarrage\n"
"        &RESTART\n"
"          LOG_PRINT_KEY T                   ! => Impression à l'écran lors de l'écriture du fichier de redémarrage\n"
"          &CHACUN\n"
"            QS_SCF0                         ! => Ne jamais écrire de fichier(s) de redémarrage pendant le cycle SCF\n"

# File: calc/cp2k/cp2k_print.c, Line: 198
msgid "      &END PRINT\n"
"\n"
"    &END SCF\n"
"! Going to the exchange-correlation section\n"
"    &XC\n"
"      &XC_FUNCTIONAL FUNCTIONAL\n"
"      &END XC_FUNCTIONAL\n"
msgstr "      &FIN D'IMPRESSION\n"
"\n"
"    &FIN SCF\n"
"! Aller à la section échanges-corrélation\n"
"    &XC\n"
"      &XC_FUNCTIONAL FONCTIONNEL\n"
"      &END XC_FUNCTIONAL\n"

