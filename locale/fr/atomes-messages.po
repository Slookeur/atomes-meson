# File: gui/main.c, Line: 179
msgid "\nUsage: atomes [OPTION]\n"
"       atomes [FILE]\n"
"       atomes [OPTION] [FILE]\n"
"       atomes [FILE1] [FILE2] ...\n"
"       atomes [OPTION1] [FILE1] [OPTION2] [FILE2] ...\n\n"
"3D atomic-scale models analysis, creation/edition and post-processing tool\n\n"
"options:\n"
"  -v, --version             version information\n"
"  -h, --help                display this help message\n\n"
"files, any number, in any order, in the following formats:\n\n"
"  atomes workspace file             : .awf\n"
"  atomes project file               : .apf\n"
"  XYZ coordinates file              : .xyz\n"
"  Chem3D coordinates file           : .c3d\n"
"  CPMD trajectory                   : .trj\n"
"  VASP trajectory                   : .xdatcar\n"
"  PDB coordinates                   : .pdb, .ent\n"
"  Crystallographic Information File : .cif\n"
"  DL-POLY history file              : .hist\n"
"  ISAACS project file               : .ipf\n\n"
" alternatively specify the file format using:\n\n"
" -awf [FILE]\n"
" -apf [FILE]\n"
" -xyz [FILE]\n"
" -c3d [FILE]\n"
" -trj [FILE]\n"
" -xdatcar [FILE]\n"
" -pdb [FILE], or, -ent [FILE]\n"
" -cif [FILE]\n"
" -hist [FILE]\n"
" -ipf [FILE]\n\n"
"ex:\n\n"
" atomes -pdb this.f file.awf -cif that.f *.xyz\n\n"
"Image rendering from the command line:\n\n"
"Usage: atomes [IMAGE_OPTIONS]\n"
"  -p, --png, --render-png    render image in PNG format\n"
"  -j, --jpg, --render-jpg    render image in JPEG format\n"
"  -o, --output=[FILE]        image file name\n"
"  -W, --width=[XSIZE]        image width\n"
"  -H, --height=[YSIZE]       image height\n"
"  -s, --style=[STYLE]        rendering style\n"
"  -r, --rep=[REP]            representation type\n"
"  -b, --box=[STYLE]          box style\n"
"  -a, --axis=[STYLE]         axis style\n"
"  -e, --acolor=[MAP]         atoms and bonds color map\n"
"  -t, --pcolor=[MAP]         ployhedra color map\n"
"  -C, --box_color=[COLOR]    box color\n"
"  -G, --back_grad=[GRAD]     background gradient type\n"
"  -B, --back_color=[COLOR]   background color\n"
"  -D, --back_dir=[DIR]       background gradient direction\n"
"  -P, --back_pos=[POS]       colors mixed position\n"
"  -U, --grad_col_a=[COL]     gradient initial color\n"
"  -V, --grad_col_b=[COL]     gradient final color\n\n"
"ex:\n\n"
" atomes --render-png --width=1920 -H 1024 --output=image.png project.apf -s ball_and_stick\n"
" atomes --jpg --style=vdw -r ortho -e pc -t pc\n\n"
msgstr "\nUtilisation : atomes [OPTION]\n"
"       atomes [FICHIER]\n"
"       atomes [OPTION] [FICHIER]\n"
"       atomes [FICHIER1] [FICHIER2] ...\n"
"       atomes [OPTION1] [FILE1] [OPTION2] [FILE2] ...\n\n"
"Outil d'analyse, de création/édition et de post-traitement de modèles 3D à l'échelle atomique\n\n"
"choix :\n"
"  -v, --version informations sur la version\n"
"  -h, --help afficher ce message d'aide\n\n"
"fichiers, n'importe quel nombre, dans n'importe quel ordre, dans les formats suivants:\n\n"
"  fichier de l'espace de travail atomes      : .awf\n"
"  fichier projet atomes                      : .apf\n"
"  Fichier de coordonnées XYZ                 : .xyz\n"
"  Fichier de coordonnées Chem3D              : .c3d\n"
"  Trajectoire CPMD                           : .trj\n"
"  Trajectoire VASP                           : .xdatcar\n"
"  Coordonnées PDB                            : .pdb, .ent\n"
"  Fichier d'informations cristallographiques : .cif\n"
"  Fichier historique DL-POLY                 : .hist\n"
"  Fichier du projet ISAACS                   : .ipf\n\n"
" vous pouvez également spécifier le format de fichier en utilisant:\n\n"
" -awf [FICHIER]\n"
" -apf [FICHIER]\n"
" -xyz [FICHIER]\n"
" -c3d [FICHIER]\n"
" -trj [FICHIER]\n"
" -xdatcar [FICHIER]\n"
" -pdb [FICHIER], ou, -ent [FICHIER]\n"
" -cif [FICHIER]\n"
" -hist [FICHIER]\n"
" -ipf [FICHIER]\n\n"
"ex :\n\n"
" atomes -pdb this.f fichier.awf -cif that.f *.xyz\n\n"
"Rendu d'image depuis la ligne de commande:\n\n"
"Utilisation: atomes [IMAGE_OPTIONS]\n"
"  -p, --png, --render-png     génère l'image au format PNG\n"
"  -j, --jpg, --render-jpg     génère l'image au format JPEG\n"
"  -o, --output=[FILE]         nom du fichier image\n"
"  -W, --width=[XSIZE]         largeur de l'image\n"
"  -H, --height=[YSIZE]        hauteur de l'image\n"
"  -s, --style=[STYLE]         style de rendu\n"
"  -r, --rep=[REP]             type de représentation\n"
"  -b, --box=[STYLE]           style de boîte\n"
"  -a, --axis=[STYLE]          style d'axe\n"
"  -e, --acolor=[MAP]          carte des couleurs des atomes et des liaisons\n"
"  -t, --pcolor=[MAP]          carte des couleurs des polyèdres\n"
"  -C, --box_color=[COULEUR]   couleur de la boîte\n"
"  -G, --back_grad=[GRAD]      type de dégradé d'arrière-plan\n"
"  -B, --back_color=[COULEUR]  couleur d'arrière-plan\n"
"  -D, --back_dir=[DIR]        direction du gradient de l'arrière-plan\n"
"  -P, --back_pos=[POS]        couleurs position mixte\n"
"  -U, --grad_col_a=[COL]      couleur initiale du dégradé\n"
"  -V, --grad_col_b=[COL]      couleur finale du dégradé\n\n"
"ex :\n\n"
" atomes --render-png --width=1920 -H 1024 --output=image.png project.apf -s ball_and_stick\n"
" atomes --jpg --style=vdw -r ortho -e pc -t pc\n\n"

