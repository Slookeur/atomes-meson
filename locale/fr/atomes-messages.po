# File: gui/calc_menu.c, Line: 776
msgid "The result of the nearest neighbors analysis\n"
"will be saved in a file that you may use afterwards.\n"
msgstr "Le résultat de l’analyse des plus proches voisins\n"
"sera enregistré dans un fichier que vous pourrez utiliser par la suite.\n"

# File: gui/calc_menu.c, Line: 817
msgid "You must specify a number of &#x3b4;r intervals >= 2\n"
"to discretize the real space between 0.0 and D<sub>max</sub>\n"
msgstr "Vous devez spécifier un nombre d'intervalles &#x3b4;r >= 2\n"
"pour discrétiser l'espace réel entre 0.0 et D<sub>max</sub>\n"

# File: gui/calc_menu.c, Line: 823
msgid "You must specify a maximum wave vector Q<sub>max</sub>[FFT]\n"
"for the FFT, with Q<sub>min</sub> < Q<sub>max</sub>[FFT] <= Q<sub>max</sub>"
msgstr "Vous devez spécifier un vecteur d'onde maximum Q<sub>max</sub>[FFT]\n"
"pour la FFT, avec Q<sub>min</sub> < Q<sub>max</sub>[FFT] <= Q<sub>max</sub>"

# File: gui/calc_menu.c, Line: 868
msgid "You must specify a number of &#x3b4;r intervals >= 2\n"
"to discretize the real space between\n"
"the shortest and the highest inter-atomic distances"
msgstr "Vous devez spécifier un nombre d'intervalles &#x3b4;r >= 2\n"
"discrétiser l'espace réel entre\n"
"les distances interatomiques les plus courtes et les plus élevées"

# File: gui/calc_menu.c, Line: 875
msgid "You must specify a number of &#x3b4;&#x3b8; intervals >= 2\n"
"to discretize the angular space between 0 and 180°"
msgstr "Vous devez spécifier un nombre d'intervalles &#x3b4;&#x3b8; >= 2\n"
"discrétiser l'espace angulaire entre 0 et 180°"

# File: gui/calc_menu.c, Line: 904
msgid "You must specify a number of %ss per size 'n' and per node\n"
"this value is used when allocating the memory to store the results\n"
"and depends on both the maximum %s size used in the search\n"
"and the system studied.\n"
"We recommend a value at least equal to 100.\n"
"If it appears that the value given is not big enough\n"
"(ex: more than 100 different %ss of size 'n' for a single node)\n"
"then the search will failed but the program will propose\n"
"you to initiate a new search using a higher value"
msgstr "Vous devez spécifier un nombre de %ss par taille 'n' et par nœud\n"
"cette valeur est utilisée pour allouer la mémoire pour stocker les résultats\n"
"et dépend à la fois de la taille maximale %s utilisée dans la recherche\n"
"et du système étudié.\n"
"Nous recommandons une valeur au moins égale à 100.\n"
"S'il apparaît que la valeur donnée n'est pas assez grande\n"
"(ex : plus de 100 %s différents de taille 'n' pour un seul nœud)\n"
"alors la recherche échouera mais le programme vous proposera\n"
"d'effectuer une nouvelle recherche en utilisant une valeur plus élevée"

# File: gui/calc_menu.c, Line: 950
msgid "You must specify the time unit\n"
"used to integrate the Newton's equations\n"
"of motion during the molecular dynamics\n"
msgstr "Vous devez préciser l'unité de temps\n"
"utilisé pour intégrer les équations de Newton\n"
"du mouvement au cours de la dynamique moléculaire\n"

# File: gui/calc_menu.c, Line: 971
msgid "You must specify the number of steps\n"
"between each of the %d configurations\n"
"found for the molecular dynamics\n"
msgstr "Vous devez préciser le nombre de pas\n"
"entre chacune des %d configurations\n"
"recensée pour la dynamique moléculaire\n"

